### **TODO-007: Stdout Guard**
- **Impact:** High - Required for rpc/print
- **Effort:** 2 hours
- **Dependencies:** TODO-004
- **Status:** ❌ Not started

**Implementation:**
1. `src/utils/output-guard.ts`:
   ```typescript
   let originalWrite: any;
   let buffer: string[] = [];

   export function takeOverStdout() {
     originalWrite = process.stdout.write.bind(process.stdout);
     process.stdout.write = (chunk: any) => {
       buffer.push(chunk.toString());
       return true;
     };
   }

   export function restoreStdout() {
     if (originalWrite) {
       process.stdout.write = originalWrite;
       buffer.forEach(chunk => originalWrite(chunk));
       buffer = [];
     }
   }
   ```

