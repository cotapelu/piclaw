      break;

    case "tool_execution_start":
      // üëâ Hi·ªÉn th·ªã: [RUNNING] bash ls -la
      this.tui?.emit('tool_start', { 
        toolName: event.toolName, 
        args: event.args 
      });
      break;

    case "tool_execution_end":
      // üëâ Hi·ªÉn th·ªã: [SUCCESS] ‚úì
      this.tui?.emit('tool_end', { 
