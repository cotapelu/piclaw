#!/usr/bin/env node
/**
 * Piclaw Idle Hooks - Type Definitions
 *
 * System để phát hiện khi agent idle (không hoạt động) và thực thi hành động.
 */

/**
 * Cấu hình idle hook trong ~/.piclaw/config.json
 */
export interface IdleHookConfig {
  /** Enable/disable idle hook */
  enabled?: boolean;
  /** Message để log/gửi khi idle (default: "Continue next task") */
  message?: string;
  /** Thời gian (seconds) không có activity trước khi coi là idle (default: 60) */
  timeoutSec?: number;
  /** Tần suất check idle (seconds) (default: 10) */
  checkIntervalSec?: number;
  /** Enable desktop notification (macOS/Linux) */
  notifyDesktop?: boolean;
}

/**
 * Reason type cho idle detection
 */
export type IdleReason = "timeout" | "signal" | "manual";

/**
 * Idle event data
 */
export interface IdleEvent {
  /** Thời gian idle bắt đầu (timestamp) */
  startTime: number;
  /** Reason */
  reason: IdleReason;
  /** Số seconds không có activity */
  idleSeconds: number;
}

/**
 * Activity types để track
 */
export type ActivityType =
  | "user_message"
  | "assistant_message"
  | "tool_start"
  | "tool_end"
  | "session_start"
  | "session_switch";

/**
 * Activity event data
 */
export interface ActivityEvent {
  type: ActivityType;
  timestamp: number;
}


