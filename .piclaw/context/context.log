#!/usr/bin/env node
/**
 * Piclaw Idle Hook Extension
 *
 * Extension theo dõi hoạt động agent và gửi thông báo khi hệ thống idle.
 *
 * Cấu hình trong ~/.piclaw/config.json:
 * {
 *   "idleHook": {
 *     "enabled": true,
 *     "message": "Continue next task.",
 *     "timeoutSec": 60,
 *     "checkIntervalSec": 10,
 *     "notifyDesktop": false
 *   }
 * }
 */

import type { ExtensionAPI } from "@mariozechner/pi-coding-agent";
import { loadConfig } from "../config/config-manager.js";
import { createIdleHookManager, type IdleHookManagerAPI } from "../hooks/idle-hooks.js";

export default function (pi: ExtensionAPI) {
	// Load config
	const config = loadConfig();
	const idleConfig = config.idleHook;

	// If disabled or not configured, skip
	if (!idleConfig || idleConfig.enabled === false) {
		if (config.verbose) {
			console.log("[IdleHookExtension] Disabled or not configured.");
		}
		return;
	}

	// Create idle manager with onIdle callback
	const idleManager: IdleHookManagerAPI = createIdleHookManager(idleConfig, (idleEvent) => {
		const msg = idleConfig.message || "Continue next task.";
		console.log(`\n[IdleHook] ${msg} (idle for ${idleEvent.idleSeconds}s)\n`);

		// Desktop notification if enabled
		if (idleConfig.notifyDesktop) {
			_sendDesktopNotification(msg);
		}
	});

	// Mark activity on various events
	const markActivity = () => idleManager.markActivity("user_activity");

	// Agent/User activity events
	pi.on("session_start", () => {
		markActivity();
	});

	pi.on("message_end", () => {
		// Assistant finished responding = activity
		idleManager.markActivity("assistant_message");
	});

	pi.on("tool_execution_start", () => {
		idleManager.markActivity("tool_start");
	});

	pi.on("tool_execution_end", () => {
		idleManager.markActivity("tool_end");
	});

	pi.on("user_input", () => {
		idleManager.markActivity("user_input");
	});

	// Start monitoring
	idleManager.start();

	if (config.verbose) {
		console.log("[IdleHookExtension] Started with config:", idleConfig);
	}

	// Cleanup on shutdown
	pi.on("session_shutdown", () => {
		idleManager.stop();
	});
}

/**
 * Send desktop notification (cross-platform)
 */
function _sendDesktopNotification(message: string): void {
	const { exec } = require("node:child_process");
	const platform = process.platform;

	try {
		if (platform === "darwin") {
			// macOS - use AppleScript
			exec(`osascript -e 'display notification "${message}" with title "PiClaw"'`);
		} else if (platform === "linux") {
			// Linux - notify-send
			// Try both with and without app name
			exec(`notify-send "PiClaw" "${message}"`);
		} else if (platform === "win32") {
			// Windows - PowerShell toast (if available)
			// Skip for now, requires extra dependencies
		}
	} catch {
		// Silently ignore notification errors
	}
}


