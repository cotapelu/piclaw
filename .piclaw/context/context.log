    const ap = p.add_phase as any;
    if (ap.tasks && typeof ap.tasks === "string") {
      try {
        ap.tasks = JSON.parse(ap.tasks);
      } catch {
        ap.tasks = ap.tasks.split(",").map((s: string) => ({ content: s.trim() }));
      }
    }
  }

  return p;
}

