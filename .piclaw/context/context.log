#!/usr/bin/env node
/**
 * Piclaw Idle Hook Extension
 *
 * Một file đơn giản - monitor agent activity và notify khi idle.
 * Cấu hình trong ~/.piclaw/config.json:
 *
 * {
 *   "idleHook": {
 *     "enabled": true,
 *     "message": "Tiếp tục công việc nào!",
 *     "timeoutSec": 60,
 *     "checkIntervalSec": 10,
 *     "notifyDesktop": false
 *   }
 * }
 */

import type { ExtensionAPI } from "@mariozechner/pi-coding-agent";
import { loadConfig } from "../config/config-manager.js";

// ============================================================================
// Types
// ============================================================================

/**
 * Cấu hình idle hook
 */
interface IdleHookConfig {
  enabled?: boolean;
  message?: string;
  timeoutSec?: number;
  checkIntervalSec?: number;
  notifyDesktop?: boolean;
}

interface IdleEvent {
  startTime: number;
  reason: "timeout";
  idleSeconds: number;
}

type ActivityType =
  | "session_start"
  | "user_input"
  | "assistant_message"
  | "tool_start"
  | "tool_end";

interface ActivityEvent {
  type: ActivityType;
  timestamp: number;
}

// ============================================================================
// Idle Hook Manager
// ============================================================================

const DEFAULT_CONFIG: Required<IdleHookConfig> = {
  enabled: true,
  message: "Continue next task.",
  timeoutSec: 60,
  checkIntervalSec: 10,
  notifyDesktop: false,
};

function createIdleHookManager(
  userConfig: IdleHookConfig | undefined,
  onIdle?: (event: IdleEvent) => void
): IdleHookManagerAPI {
  const config = { ...DEFAULT_CONFIG, ...userConfig };
  let lastActivity = Date.now();
  let isIdle = false;
  let idleSince: number | null = null;
  let intervalId: NodeJS.Timeout | null = null;
  const activityEmitter = new EventTarget();

  function markActivity(type: ActivityType): void {
    const now = Date.now();
    lastActivity = now;

    if (isIdle) {
      isIdle = false;
      idleSince = null;
    }

    activityEmitter.dispatchEvent(
      new CustomEvent("activity", { detail: { type, timestamp: now } })
    );
  }

  function checkIdle(): void {
    if (!config.enabled) return;

    const now = Date.now();
    const idleTime = now - lastActivity;
    const timeoutMs = config.timeoutSec * 1000;

    if (!isIdle && idleTime >= timeoutMs) {
      isIdle = true;
      idleSince = lastActivity;

      const idleEvent: IdleEvent = {
        startTime: lastActivity,
        reason: "timeout",
        idleSeconds: Math.floor(idleTime / 1000),
      };

      onIdle?.(idleEvent);
      console.log(`\n[IdleHook] ${config.message} (idle for ${idleEvent.idleSeconds}s)\n`);

      if (config.notifyDesktop) {
        _sendDesktopNotification(config.message);
      }
    }
  }

  function start(): void {
    if (intervalId) return;
    const intervalMs = config.checkIntervalSec * 1000;
    intervalId = setInterval(checkIdle, intervalMs);
  }

  function stop(): void {
    if (intervalId) {
      clearInterval(intervalId);
      intervalId = null;
    }
  }

  function onIdleEventListener(handler: (e: IdleEvent) => void): () => void {
    // Simple one-time use; in a real impl we'd manage listeners
    return () => {}; // No-op for simplicity
  }

  function onActivityListener(handler: (e: ActivityEvent) => void): () => void {
    activityEmitter.addEventListener("activity", handler as EventListener);
    return () => activityEmitter.removeEventListener("activity", handler as EventListener);
  }

  if (config.enabled) {
    start();
  }

  return {
    markActivity,
    getIdleState: () => ({
      isIdle,
      idleSeconds: isIdle && idleSince ? Math.floor((Date.now() - idleSince) / 1000) : 0,
      lastActivity,
    }),
    checkIdle,
    start,
    stop,
    onIdle: onIdleEventListener,
    onActivity: onActivityListener,
  };
}

interface IdleHookManagerAPI {
  markActivity(type: ActivityType): void;
  getIdleState(): { isIdle: boolean; idleSeconds: number; lastActivity: number };
  checkIdle(): void;
  start(): void;
  stop(): void;
  onIdle(handler: (e: IdleEvent) => void): () => void;
  onActivity(handler: (e: ActivityEvent) => void): () => void;
}

// ============================================================================
// Desktop Notification
// ============================================================================

function _sendDesktopNotification(message: string): void {
  const { exec } = require("node:child_process");
  const platform = process.platform;

  try {
    if (platform === "darwin") {
      exec(`osascript -e 'display notification "${message}" with title "PiClaw"'`);
    } else if (platform === "linux") {
      exec(`notify-send "PiClaw" "${message}"`);
    }
  } catch {
    // ignore
  }
}

// ============================================================================
// Extension
// ============================================================================

export default function (pi: ExtensionAPI) {
  const config = loadConfig();
  const idleConfig = config.idleHook;

  if (!idleConfig || idleConfig.enabled === false) {
    if (config.verbose) {
      console.log("[IdleHook] Disabled");
    }
    return;
  }

  const idleManager = createIdleHookManager(idleConfig, (event) => {
    // Already logged inside manager, but hook can also notify via UI
    // Optional: pi.ui?.notify?.(idleConfig.message || "Continue next task.");
  });

  // Listen to activity events
  pi.on("session_start", () => idleManager.markActivity("session_start"));
  pi.on("input", () => idleManager.markActivity("user_input"));
  pi.on("message_end", () => idleManager.markActivity("assistant_message"));
  pi.on("tool_execution_start", () => idleManager.markActivity("tool_start"));
  pi.on("tool_execution_end", () => idleManager.markActivity("tool_end"));

  idleManager.start();

  if (config.verbose) {
    console.log("[IdleHook] Started:", idleConfig);
  }

  // Cleanup
  pi.on("session_shutdown", () => idleManager.stop());
}


