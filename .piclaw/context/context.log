```ts
import type { ExtensionAPI } from "@mariozechner/pi-coding-agent";

// ============================================================================
// Simple Idle Hook - no config needed
// ============================================================================

const IDLE_TIMEOUT_MS = 60_000; // 60 seconds
const CHECK_INTERVAL_MS = 10_000; // 10 seconds
const IDLE_MESSAGE = "Continue next task.";

export default function (pi: ExtensionAPI) {
  let lastActivity = Date.now();
  let intervalId: NodeJS.Timeout | null = null;
  let isIdle = false;

  function markActivity() {
    lastActivity = Date.now();
    isIdle = false;
  }

  function checkIdle() {
    const now = Date.now();
    if (now - lastActivity > IDLE_TIMEOUT_MS && !isIdle) {
      isIdle = true;
      console.log(`\n[IdleHook] ${IDLE_MESSAGE} (idle for ${Math.floor((now - lastActivity)/1000)}s)\n`);
      
      // Optionally trigger agent to continue?
      // Could use pi.exec but better not; just log for now.
    }
  }

  // Activity sources
  pi.on("session_start", markActivity);
  pi.on("input", markActivity); // user typing
  pi.on("message_end", markActivity); // assistant finished
  pi.on("tool_execution_start", markActivity);
  pi.on("tool_execution_end", markActivity);

  // Start monitoring
  intervalId = setInterval(checkIdle, CHECK_INTERVAL_MS);

  // Cleanup on shutdown
  pi.on("session_shutdown", () => {
    if (intervalId) clearInterval(intervalId);
  });
}
```

