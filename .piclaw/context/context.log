    it('should use PICLAW_SHARE_VIEWER_URL if set', () => {
      vi.stubEnv('PICLAW_SHARE_VIEWER_URL', 'https://custom.example.com/');
      const url = config.getShareViewerUrl('xyz789');
      expect(url).toBe('https://custom.example.com/#xyz789');
    });
  });
});


