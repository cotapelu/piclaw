```ts
#!/usr/bin/env node
/**
 * Auto Continue Extension
 *
 * Khi agent idle (sau khi trả lời xong) quá lâu (default 60s),
 * tự động gửi message "Continue next task" để nhắc LLM tiếp tục.
 *
 * Dựa trên pattern từ todos-tool.ts (api.sendMessage).
 */

import type { ExtensionAPI, ExtensionContext } from "@mariozechner/pi-coding-agent";

export default function (pi: ExtensionAPI) {
  let idleTimer: NodeJS.Timeout | null = null;
  let lastCtx: ExtensionContext | null = null;
  const IDLE_TIMEOUT_MS = 60_000; // 60 seconds

  // Reset timer và lưu context
  function resetTimer(ctx: ExtensionContext) {
    if (idleTimer) {
      clearTimeout(idleTimer);
      idleTimer = null;
    }
    lastCtx = ctx;
  }

  // Bắt đầu đếm thời gian idle
  function startIdleTimer(ctx: ExtensionContext) {
    resetTimer(ctx);
    idleTimer = setTimeout(async () => {
      // Gửi message để tiếp tục
      if (lastCtx?.agent) {
        try {
          await lastCtx.agent.sendMessage({
            role: "user",
            content: "Continue next task."
          });
          // Sau khi gửi, đợi agent xử lý và tiếp tục
          if (typeof lastCtx.agent.waitForIdle === "function") {
            await lastCtx.agent.waitForIdle();
            if (typeof lastCtx.agent.continue === "function") {
              await lastCtx.agent.continue();
            }
          }
        } catch (e) {
          console.error("[AutoContinue] Failed:", e);
        }
      }
      // Sau khi gửi, reset timer để không gửi lại cho đến khi có activity mới
      idleTimer = null;
    }, IDLE_TIMEOUT_MS);
  }

  // Khi session bắt đầu
  pi.on("session_start", (_event, ctx) => {
    resetTimer(ctx);
  });

  // Khi user nhập input -> không idle nữa
  pi.on("input", (_event, ctx) => {
    resetTimer(ctx);
  });

  // Khi assistant bắt đầu trả lời -> reset (vẫn đang active)
  pi.on("message_start", (_event, ctx) => {
    resetTimer(ctx);
  });

  // Khi assistant kết thúc trả lời -> bắt đầu đếm idle
  pi.on("message_end", (_event, ctx) => {
    startIdleTimer(ctx);
  });

  // Cleanup khi shutdown
  pi.on("session_shutdown", () => {
    if (idleTimer) {
      clearTimeout(idleTimer);
      idleTimer = null;
    }
    lastCtx = null;
  });
}
```

